install.packages(c("ggplot2", "plyr"))
#Read in titatnic data
#do mode imputation on missing values
# run a selection of models on survival
library(plyr)
setwd("C:\\Users\\TeamLorenzen\\Documents\\KaggleTitanic")
train<-read.csv("train.csv")
test<-read.csv("test.csv")
NMode <- function(x) {
ux <- unique(x[!(is.na(x))])
ux[which.max(tabulate(match(x, ux)))]
}
ModeImpute<-function(v1){
v1[is.na(v1)] <- NMode(v1)
return(v1)
}
qq <- ModeImpute(train$Age)
train2<-data.frame(lapply(train,ModeImpute))
test2<-data.frame(lapply(test,ModeImpute))
#now we have cleared our data of missing values and have train and test datasets ready to work.
#first use average survival by age and sex
train3<-train2
train3$Age<-round(train3$Age,0)
ImputedSurvivalByAgeGender<-ddply(train3,.(Age,Sex),summarize,Rate=round(mean(Survived),0) )
#now can use a lookup table  -- get gender and age (closest age to page in train dataset) and apply rate survival rate
#join that to train2 to make submissiong file
test3<-test2
test3$Age=round(test3$Age,0)
Pred<-merge(test3,ImputedSurvivalByAgeGender,by=c("Age", "Sex"),all.x=TRUE)
Pred$Rate[is.na(Pred$Rate)]<-1
Pred$Survived<-Pred$Rate
submission<-data.frame(Pred$PassengerId,Pred$Survived)
names(submission)<-c("PassengerID","Survived")
write.csv(submission,file="Submit0.csv",row.names=FALSE)
#Ok, now try out a logistic regression and a random forest . ..
library(randomForest)
set.seed(31415)
#rfpred<-as.data.frame(cbind(train3$Age,train3$Pclass,train3$SibSp,train3$Parch,train3$Sex,train3$Ticket))
#names(rfpred)<-c("Age","Pclass","Sibsp","Parch","Sex","Ticket")
rfpred<-as.data.frame(cbind(train3$Pclass,train3$Sex,train3$SibSp))
names(rfpred)<-c("Pclass","Sex","SibSp")
SurvFactor<-as.factor(train3$Survived)
rf1<-randomForest(rfpred,y=SurvFactor,importance=TRUE, ntree=200)
#make predictions on test3
test4<-as.data.frame(cbind(test3$Pclass,test3$Sex,test3$SibSp))
names(test4)<-names(rfpred)
predRf1<-predict(rf1,newdata=test4)
names(predRf1)<-"Survived"
#make submission dataframe
submission2<-as.data.frame(cbind(test3$PassengerId,predRf1))
names(submission2)<-c("PassengerID","Survived")
#ok, 0 and 1 went to 1 and 2 . . .ill fix the obvious way for now
submission2[,2]=submission[,2]-1
write.csv(submission,file="Submit2.csv",row.names=FALSE)
